generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profesor {
  id          String      @id @default(cuid())
  email       String      @unique
  contrasena  String
  nombre      String
  creadoEn    DateTime    @default(now()) @map("creado_en")
  actividades Actividad[]

  @@map("profesores")
}

model Actividad {
  id            String        @id @default(cuid())
  codigo        String        @unique
  titulo        String
  descripcion   String?
  tiempoLimite  Int           @default(600) @map("tiempo_limite")
  activa        Boolean       @default(true)
  creadoEn      DateTime      @default(now()) @map("creado_en")
  actualizadoEn DateTime      @updatedAt @map("actualizado_en")
  profesorId    String        @map("profesor_id")
  profesor      Profesor      @relation(fields: [profesorId], references: [id])
  preguntas     Pregunta[]
  sesionesJuego SesionJuego[]

  @@index([profesorId])
  @@index([codigo])
  @@map("actividades")
}

model Pregunta {
  id          String    @id @default(cuid())
  orden       Int
  respuesta   String
  ejemplo     String
  pregunta    String
  pista       String?
  actividadId String    @map("actividad_id")
  actividad   Actividad @relation(fields: [actividadId], references: [id], onDelete: Cascade)

  @@index([actividadId])
  @@map("preguntas")
}

model SesionJuego {
  id              String            @id @default(cuid())
  nombreAlumno    String            @map("nombre_alumno")
  iniciadoEn      DateTime          @default(now()) @map("iniciado_en")
  finalizadoEn    DateTime?         @map("finalizado_en")
  tiempoUsado     Int?              @map("tiempo_usado")
  puntaje         Int               @default(0)
  totalPreguntas  Int               @map("total_preguntas")
  actividadId     String            @map("actividad_id")
  actividad       Actividad         @relation(fields: [actividadId], references: [id])
  respuestas      RespuestaAlumno[]

  @@index([actividadId])
  @@map("sesiones_juego")
}

model RespuestaAlumno {
  id            String      @id @default(cuid())
  ordenPregunta Int         @map("orden_pregunta")
  correcta      Boolean
  tiempoRespuesta Int?      @map("tiempo_respuesta")
  sesionId      String      @map("sesion_id")
  sesion        SesionJuego @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@index([sesionId])
  @@map("respuestas_alumnos")
}
